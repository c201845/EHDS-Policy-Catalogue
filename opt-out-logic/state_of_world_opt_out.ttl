@prefix sotw: <https://w3id.org/force/sotw#> .

<http://example.org/request> a sotw:EvaluationRequest ;
    sotw:evaluatedParty <http://example.org/request> ;
    sotw:evaluatedAction odrl:read ;
    sotw:evaluatedTarget eu-ehds:ElectronicHealthData ;
    sotw:requestParameter [
        sotw:describesFeature :OptOut ;
        sotw:value "true"^^xsd:boolean
    ] , [
        sotw:describesFeature sotw:Purpose ;
        sotw:value eu-ehds:HealthcareScientificResearch
] .