PREFIX dpv: <https://w3id.org/dpv#>
PREFIX dpv-odrl: <https://w3id.org/dpv/mappings/odrl#>
PREFIX eu-ehds: <https://w3id.org/dpv/legal/eu/ehds#>
PREFIX odrl: <http://www.w3.org/ns/odrl/2/>

<http://example.org/policy/human-oversight-research> a odrl:Set ;
    odrl:uid <http://example.org/policy/human-oversight-research> ;
    odrl:profile dpv-odrl: ;
    odrl:permission [
        odrl:action odrl:read ;
        odrl:target eu-ehds:ElectronicHealthData ;
        odrl:assigner <http://example.org/party/alice> ;
        odrl:constraint [
            odrl:leftOperand dpv-odrl:Purpose ;
            odrl:operator odrl:isA ;
            odrl:rightOperand eu-ehds:HealthcareScientificResearch], [ 
            odrl:leftOperand dpv-odrl:HumanInvolvement ;
            odrl:operator odrl:isA ;
            odrl:rightOperand dpv:HumanInvolvementForOversight ] ] .
