PREFIX dpv-odrl: <https://w3id.org/dpv/mappings/odrl#>
PREFIX eu-ehds: <https://w3id.org/dpv/legal/eu/ehds#>
PREFIX odrl: <http://www.w3.org/ns/odrl/2/>

<http://example.org/policy/sec-use-research> a odrl:Set ;
    odrl:uid <http://example.org/policy/sec-use-research> ;
    odrl:profile dpv-odrl: ;
    odrl:permission [
        odrl:action odrl:read ;
        odrl:target [ 
            a odrl:AssetCollection ;
            odrl:source <http://example.org/data/health> ;
            odrl:refinement [
                odrl:leftOperand dpv-odrl:PersonalData ;
                odrl:operator odrl:isAnyOf ;
                odrl:rightOperand eu-ehds:GenomicData, eu-ehds:BiobankData, eu-ehds:EHRData ]] ;
        odrl:assigner <http://example.org/party/HDAB> ;
        odrl:constraint [
            odrl:leftOperand dpv-odrl:Purpose ;
            odrl:operator odrl:isAnyOf ;
            odrl:rightOperand eu-ehds: HealthcareScientificResearch,
                              eu-ehds: EnsureQualitySafetyHealthcare,
                              eu-ehds: PublicPolicyMaking, 
                              eu-ehds: SupportAuthoritiesRegulatoryActivities, 
                              eu-ehds: ImproveHealthcareEducation,
                              eu-ehds: EnsureQualitySafetyMedicalDevices,
                              eu-ehds: EnsureQualitySafetyMedicalDevices,
                              eu-ehds: ProtectAgainstCrossBorderThreatsToHealth,
                              eu-ehds: PublicHealthSurveillance,
                              eu-ehds: PublicInterestRelatedToHealth,
                              eu-ehds: EnsureQualitySafetyMedicalDevices,
                              eu-ehds: PublicPolicyMaking,
                              eu-ehds: SupportAuthoritiesRegulatoryActivities,
                              eu-ehds: ProvideHealthcareOfficialStatistics,
                              eu-ehds: ImproveHealthcareEducation,
                              eu-ehds: DevelopPublicHealthProductsAndServices,
                              eu-ehds: TrainTestAndEvaluateAISystemsAlgorithms,
                              eu-ehds: TrainTestAndEvaluateHealthAlgorithms,
                              eu-ehds: TrainTestAndEvaluateHealthAppsAlgorithms,
                              eu-ehds: TrainTestAndEvaluateMedicalDevicesAlgorithms,
                              eu-ehds: ImproveHealthcare
        ] 
    ].
